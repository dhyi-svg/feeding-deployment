<launch>
  <!-- ===== Serial ports (from base_sensors.launch) ===== -->
  <arg name="port2" default="/dev/serial/by-path/pci-0000:00:14.0-usb-0:4.4.3:1.0-port0"/>
  <arg name="port1" default="/dev/serial/by-path/pci-0000:00:14.0-usb-0:4.4.4:1.0-port0"/>
  <arg name="baud"  default="115200"/>

  <!-- ===== Camera and odometry frames ===== -->
  <arg name="odom_frame"        default="odom"/>
  <arg name="map_frame"         default="map"/>
  <arg name="camera_name"       default="zed_mini"/>
  <arg name="camera_base_frame" default="zed_mini_base_link"/>

  <!-- ===== Lidar poses w.r.t. vention_base_link ===== -->
  <arg name="lidar_r_x"   default="0.2575"/>
  <arg name="lidar_r_y"   default="-0.135"/>
  <arg name="lidar_r_z"   default="0.415"/>
  <arg name="lidar_r_rr"  default="3.14159"/>
  <arg name="lidar_r_rp"  default="0.0"/>
  <arg name="lidar_r_ry"  default="0.0"/>

  <arg name="lidar_l_x"   default="0.2575"/>
  <arg name="lidar_l_y"   default="0.135"/>
  <arg name="lidar_l_z"   default="0.415"/>
  <arg name="lidar_l_rr"  default="3.14159"/>
  <arg name="lidar_l_rp"  default="0.0"/>
  <arg name="lidar_l_ry"  default="0.0"/>

  <!-- ===== Combined URDF: arm mounted on mobile base ===== -->
  <param name="robot_description"
         command="$(find xacro)/xacro --inorder $(find feeding_deployment)/urdf/combined.urdf.xacro" />

  <!-- ===== Joint and robot state publishing (single unified tree) ===== -->
  <node pkg="joint_state_publisher"
        type="joint_state_publisher"
        name="joint_state_publisher">
    <rosparam param="source_list">["robot_joint_states", "wrist_joint_states"]</rosparam>
    <param name="rate" value="100"/>
  </node>

  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher">
    <param name="ignore_timestamp" value="true"/>
  </node>

  <!-- ===== Lidar static transforms (from base_sensors.launch) ===== -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_base_to_lidar_r"
        args="$(arg lidar_r_x) $(arg lidar_r_y) $(arg lidar_r_z) $(arg lidar_r_rr) $(arg lidar_r_rp) $(arg lidar_r_ry) vention_base_link lidar_r"/>

  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_base_to_lidar_l"
        args="$(arg lidar_l_x) $(arg lidar_l_y) $(arg lidar_l_z) $(arg lidar_l_rr) $(arg lidar_l_rp) $(arg lidar_l_ry) vention_base_link lidar_l"/>

  <!-- ===== Lidar drivers (from base_sensors.launch) ===== -->
  <group ns="lidar_r">
    <node pkg="rplidar_ros" type="rplidarNode" name="rplidarNode" output="screen">
      <param name="serial_port" value="$(arg port1)"/>
      <param name="serial_baudrate" value="$(arg baud)"/>
      <param name="frame_id" value="lidar_r"/>
      <param name="angle_compensate" value="true"/>
      <param name="inverted" value="false"/>
    </node>
  </group>

  <group ns="lidar_l">
    <node pkg="rplidar_ros" type="rplidarNode" name="rplidarNode" output="screen">
      <param name="serial_port" value="$(arg port2)"/>
      <param name="serial_baudrate" value="$(arg baud)"/>
      <param name="frame_id" value="lidar_l"/>
      <param name="angle_compensate" value="true"/>
      <param name="inverted" value="false"/>
    </node>
  </group>

  <!-- ===== ZED Mini (passive witness; publishes NO TF) ===== -->
  <!-- Since Jul 2026 the fused wheel+IMU EKF (ekf_fused_imu_wheel, below) owns
       odom -> vention_base_link. The ZED's VIO odom TOPIC keeps publishing
       (drift traces / sanitizer / health monitor witness) but publish_tf=false
       keeps its estimate out of the TF tree entirely.

       The camera MOUNT transform (vention_base_link -> zed_mini_base_link,
       measured +0.3176/0/+0.386) is owned by the ZED's own description
       publisher via base_frame + cam_pos_* below; it is deliberately NOT in
       combined.urdf.xacro (two static publishers of the same child frame
       fight, last-writer-wins -> "unconnected trees"; bit us 2026-07-13 when
       the wrapper's default base_frame:=base_link rooted the camera under an
       orphan frame).

       NOTE the nodelet reads general/base_frame (pos_tracking/base_frame is
       NOT a real param); it must stay zed_mini_base_link so the odom topic's
       child_frame_id and the camera_center->base lookup
       (getCamera2BaseTransform) keep their semantics. -->
  <include file="$(find zed_wrapper)/launch/zedm.launch">
    <arg name="camera_name"  value="$(arg camera_name)"/>
    <arg name="camera_model" value="zedm"/>
    <arg name="base_frame"   value="vention_base_link"/>
    <arg name="cam_pos_x"    value="0.3176"/>
    <arg name="cam_pos_z"    value="0.386"/>
  </include>

  <param name="/$(arg camera_name)/zed_node/pos_tracking/publish_tf"     value="false"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/publish_map_tf" value="false"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/odometry_frame" value="$(arg odom_frame)"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/map_frame"      value="$(arg map_frame)"/>
  <param name="/$(arg camera_name)/zed_node/general/base_frame"          value="$(arg camera_base_frame)"/>
  <!-- Disable ZED spatial memory / loop closure. With area_memory on, the SDK
       detects previously-visited areas and applies discrete pose corrections.
       Those corrections land in the map/pose output (map->odom), NOT the odom
       topic; since publish_map_tf=false and we consume /zed_node/odom, they are
       mostly unused anyway, but keeping it off guarantees no loop-closure
       machinery runs and saves SDK compute. Also ensure no saved map is
       loaded/re-saved (both already default off in common.yaml). -->
  <param name="/$(arg camera_name)/zed_node/pos_tracking/area_memory"              value="false"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/save_area_memory_db_on_exit" value="false"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/area_memory_db_path"      value=""/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/floor_alignment"          value="false"/>
  <!-- Constrain VIO to the ground plane: fix z=0, roll=pitch=0. Under bright
       light (sunlight/flashlight) the ZED loses visual features and its 6-DOF
       pose drifts OUT OF PLANE (observed: z->-0.77 m, pitch ~-52 deg, frame
       flips), which Cartographer then absorbs into map->odom. This clamps the
       out-of-plane DOF so odom stays planar. NOTE: does NOT constrain yaw;
       in-plane yaw can still drift with no visual features (needs wheel+IMU or
       a yaw vs gyro gate). See navlog_20260709_144001. -->
  <param name="/$(arg camera_name)/zed_node/pos_tracking/two_d_mode"     value="true"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/fixed_z_value"  value="0.0"/>

  <!-- Convert ZED odom pose deltas into odom feedback for move_base (from base_sensors.launch) -->
  <node pkg="feeding_deployment"
        type="zed_pose_to_odom_feedback.py"
        name="zed_pose_to_odom_feedback"
        output="screen">
    <param name="input_odom_topic" value="/$(arg camera_name)/zed_node/odom"/>
    <param name="output_odom_topic" value="/move_base/odom_feedback"/>
    <!-- Sanitized full-pose ZED odom (single-frame VIO teleports dropped).
         Since Jul 2026 nothing authoritative consumes it (Cartographer rides
         /odometry/fused_imu_wheel); kept for the drift traces + nav logs. -->
    <param name="sanitized_odom_topic" value="/$(arg camera_name)/zed_node/odom_sanitized"/>
    <!-- Ablation switches + tunables (enable_sanitizer, enable_windowed_diff,
         gate thresholds, vel_diff_window). Flip either flag false to reproduce
         original behavior for that stage. -->
    <rosparam command="load" file="$(find feeding_deployment)/config/nav/odom_pipeline.yaml"/>
  </node>

  <!-- ===== Fused wheel+IMU odometry (AUTHORITATIVE odom->base) ===== -->
  <!-- Encoder odometry from the NUC base RPC. Blocks retrying the RPC at
       startup if base_server isn't up yet; respawn covers crashes only. -->
  <node pkg="feeding_deployment" type="wheel_odom_publisher.py"
        name="wheel_odom_publisher" output="screen"
        respawn="true" respawn_delay="2"/>

  <!-- Stillness-calibrated debiasing of the ZED gyro (the raw gyro carries a
       per-boot bias lottery, measured -131 deg/h on Jul 10). Wait for its
       "first calibration complete" log (needs >=15 s of stillness with fresh
       /wheel_odom) before trusting yaw. -->
  <node pkg="feeding_deployment" type="gyro_bias_estimator.py"
        name="gyro_bias_estimator" output="screen"
        respawn="true" respawn_delay="2"/>

  <!-- The authoritative EKF: wheel vx (+advisory wheel vyaw) + debiased gyro
       yaw-rate. Owns odom->vention_base_link (publish_tf override below); the
       ZED VIO is excluded by pointing odom0 at a topic nobody publishes.
       Cartographer's odom topic and TEB's odom feedback both consume
       /odometry/fused_imu_wheel.
       Deliberately NO respawn: an auto-restarted EKF resumes at the odom
       origin, a silent unsanitized teleport into Cartographer's extrapolator
       (jul02 corruption class). If it ever dies, the stack goes loudly dead
       (carto collator stalls, TEB loses odom); restart sensors (pane 2),
       then prefix+r. The wheel/gyro nodes above DO respawn safely: the EKF
       fuses only the wheel TWIST (reset-proof) and the estimator simply
       re-calibrates at the next stillness. -->
  <node pkg="robot_localization" type="ekf_localization_node"
        name="ekf_fused_imu_wheel" clear_params="true" output="screen">
    <rosparam command="load"
              file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
    <param name="publish_tf" value="true"/>
    <param name="odom0" value="/odometry/_zed_vio_disabled"/>
    <param name="imu0" value="/$(arg camera_name)/zed_node/imu/data_debiased"/>
    <rosparam param="imu0_config">[false, false, false, false, false, false, false, false, false, false, false, true, false, false, false]</rosparam>
    <param name="imu0_differential" value="false"/>
    <param name="imu0_relative" value="false"/>
    <param name="imu0_queue_size" value="20"/>
    <remap from="odometry/filtered" to="/odometry/fused_imu_wheel"/>
  </node>

  <!-- ===== Arm-specific TFs (from robot.launch, with arm_ prefix) ===== -->
  <!-- Arm RealSense camera mount on arm_end_effector_link -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="camera_link_broadcaster"
        args="-0.04611404 0.0837761 0.11 0.7071068 0 0 0.7071068 arm_end_effector_link camera_link"/>

  <!-- Tool base frames (fixed at identity from arm_finger_tip) -->
  <node pkg="tf" type="static_transform_publisher" name="static_tf_feeding_tool"
        args="0 0 0 0 0 0 1 arm_finger_tip arm_forkbase 10"/>
  <node pkg="tf" type="static_transform_publisher" name="static_tf_drinking_tool"
        args="0 0 0 0 0 0 1 arm_finger_tip arm_drinkbase 10"/>
  <node pkg="tf" type="static_transform_publisher" name="static_tf_wiping_tool"
        args="0 0 0 0 0 0 1 arm_finger_tip arm_wipebase 10"/>

  <!-- ===== Arm RealSense camera driver (from robot.launch) ===== -->
  <!-- D435: run color and depth at 1280x720 @ 30 Hz (depth's max-at-30Hz),
       so both streams are at native res for depth alignment / pointcloud. -->
  <!-- DISABLED [2026-07-10]: turned off to test hypothesis that RealSense and ZED
       compete for USB bandwidth/resources, causing the ZED to die. If confirmed,
       the fix is to move them to separate USB controllers rather than leave this off.
       NOTE: when this is disabled, the camera frequency + resolution checks in
       watchdog.py MUST also be disabled or the watchdog E-stops the arm immediately.
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="align_depth" value="true"/>
    <arg name="enable_sync" value="true"/>
    <arg name="filters" value="pointcloud"/>
    <arg name="color_width"  value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps"    value="30"/>
    <arg name="depth_width"  value="1280"/>
    <arg name="depth_height" value="720"/>
    <arg name="depth_fps"    value="30"/>
  </include>
  -->
  <!-- END RealSense disable -->


  <!-- ===== Arm FT sensor driver (from robot.launch) ===== -->
  <include file="$(find netft_rdt_driver)/launch/ft_sensor.launch">
    <arg name="ip_address" value="192.168.1.7"/>
    <arg name="rate" value="1000"/>
  </include>

  <!-- ===== ROS bridge for web app (from robot.launch) ===== -->
  <!--Bohan [Jun 18, 2026]: to allow rosbridge serves TLS automatically when certfile + keyfile are present-->
  <node pkg="rosbridge_server" type="rosbridge_websocket" name="rosbridge_websocket" output="screen">
    <param name="certfile" value="/home/isacc/certs/192.168.1.2.pem"/>
    <param name="keyfile"  value="/home/isacc/certs/192.168.1.2-key.pem"/>
    <param name="port"     value="9090"/>
  </node>


</launch>
