<launch>
  <!-- Make sure TF + /map + scans are already running:
       - Cartographer (publishing map->odom)
       - UKF/VSLAM (publishing odom->vention_base_link)
       - lidar topics: /lidar_l/scan and /lidar_r/scan
  -->

  <!-- move_base -->
  <!-- move_base -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <!-- <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/> -->
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>

    <rosparam file="$(find feeding_deployment)/config/nav/costmap_common.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find feeding_deployment)/config/nav/costmap_common.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find feeding_deployment)/config/nav/global_costmap.yaml" command="load"/>
    <rosparam file="$(find feeding_deployment)/config/nav/local_costmap.yaml" command="load"/>
    <!-- <rosparam file="$(find feeding_deployment)/config/nav/dwa_local_planner.yaml" command="load"/> -->
    <rosparam file="$(find feeding_deployment)/config/nav/teb_local_planner.yaml" command="load"/>

    <param name="planner_patience" value="15.0"/>
    <param name="controller_patience" value="15.0"/>

    <!-- optional but often helpful for your exact symptom -->
    <param name="planner_frequency" value="1.0"/>
    <param name="controller_frequency" value="10.0"/>
  </node>





  <!-- cmd_vel bridge: /cmd_vel -> set_speeds RPC to BaseInterface on the NUC.
       Runs on the compute box; the Arduino is on the NUC behind base_server.py.
       The lost-command stop lives on the NUC (BaseInterface), not here. -->
  <node pkg="feeding_deployment"
        type="cmd_vel_bridge_basicmicro.py"
        name="cmd_vel_bridge_basicmicro"
        output="screen"
        cwd="node">

    <!-- conservative defaults; tune these. linear_scale is kept low on purpose:
         autonomous nav stays slow, which helps localization. -->
    <param name="linear_scale" value="800.0"/>
    <param name="angular_scale" value="600.0"/>
    <param name="max_speed_units" value="2500"/>
    <!-- Ratio-preserving stiction floor (units); scales both wheels together so
         slow commands still move without flattening arcs. 0 disables. -->
    <param name="min_move_units" value="250"/>
  </node>

  <!-- ZED-divergence safety interlock: asserts /nav_safety_hold when the ZED VIO
       diverges (tracking status != OK, or odom implies impossible velocity). The
       cmd_vel bridge above commands zero while held, so the base stops until the
       ZED recovers.
       Ablation: zed_interlock:=false disables the whole chain: the monitor is
       not launched, so the bridge never gates and the manager never pauses
       (both are no-ops without /nav_safety_hold messages). The legacy
       NO_ZED_INTERLOCK=1 env var still works as the default. -->
  <arg name="zed_interlock" default="$(eval optenv('NO_ZED_INTERLOCK', '0') != '1')"/>
  <node if="$(arg zed_interlock)"
        pkg="feeding_deployment"
        type="zed_health_monitor.py"
        name="zed_health_monitor"
        output="screen">
    <param name="odom_topic" value="/zed_mini/zed_node/odom"/>
    <param name="hold_topic" value="/nav_safety_hold"/>
    <param name="max_lin_vel" value="0.5"/>
    <param name="max_ang_vel" value="1.5"/>
    <param name="recovery_stable_s" value="2.0"/>
  </node>
</launch>