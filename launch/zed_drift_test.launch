<launch>
  <!-- ZED drift test: map-anchored live traces of wheel odom vs ZED odom
       (raw + sanitized) vs live Cartographer, driven by Xbox teleop.

       Bring-up order:
         1. NUC: base_server up (tmux 'robot', launch_base)
         2. compute: sensors.launch
         3. compute: THIS file
         4. your terminal: rosrun feeding_deployment drift_lock.py
            -> let localization settle, press ENTER to lock the anchor,
               then drive with the X-deadman.

       MUTUALLY EXCLUSIVE with navigation.launch and shared_autonomy.launch:
       they declare the same node names (cmd_vel_bridge_basicmicro,
       shared_autonomy_teleop) and ROS silently kills the older instance.
       If cartographer localization is ALREADY running (tmux pane), pass
       carto:=false. -->

  <arg name="load_state_filename"
       default="$(find feeding_deployment)/maps/aimee-7-3.pbstream"/>
  <arg name="carto"   default="true"/>
  <arg name="rviz"    default="true"/>
  <arg name="record"  default="false"/>
  <arg name="monitor" default="true"/>
  <arg name="log_dir"
       default="$(find feeding_deployment)/src/feeding_deployment/integration/log/system_logs"/>

  <!-- Cartographer localization on the known map (map->odom). -->
  <include if="$(arg carto)"
           file="$(find feeding_deployment)/launch/cartographer_localization.launch">
    <arg name="load_state_filename" value="$(arg load_state_filename)"/>
  </include>

  <!-- Teleop: Xbox controller -> Twist on /cmd_vel_teleop (deadman-gated).
       Verbatim from shared_autonomy.launch; max_vel_x/max_vel_theta are
       REQUIRED (the node has no code defaults). -->
  <node pkg="feeding_deployment"
        type="shared_autonomy_teleop.py"
        name="shared_autonomy_teleop"
        output="screen"
        cwd="node">
    <param name="deadman_button" value="2"/>   <!-- X: hold to drive -->
    <param name="done_button" value="3"/>      <!-- Y (unused here) -->
    <param name="axis_linear" value="1"/>
    <param name="axis_angular" value="0"/>
    <param name="cmd_vel_topic" value="/cmd_vel_teleop"/>
    <param name="max_vel_x" value="0.10"/>
    <param name="max_vel_theta" value="0.1667"/>
    <param name="deadband" value="0.12"/>
  </node>

  <!-- cmd_vel bridge: /cmd_vel_teleop -> set_speeds RPC to the NUC.
       Verbatim params from navigation.launch. Teleop is executed with
       priority and without the ZED-divergence hold gate. -->
  <node pkg="feeding_deployment"
        type="cmd_vel_bridge_basicmicro.py"
        name="cmd_vel_bridge_basicmicro"
        output="screen"
        cwd="node">
    <!-- Physically calibrated 2026-07-09 (see navigation.launch). ~4-6x higher than
         before, so the base now runs the full commanded speed; lower the teleop
         max_vel_x/theta above and TEB max_vel_* before fast autonomous runs. -->
    <param name="linear_scale" value="4874.0"/>
    <param name="angular_scale" value="2600.0"/>
    <param name="max_speed_units" value="2500"/>
    <param name="min_move_units" value="100"/>
  </node>

  <!-- Observers (wheel odom + tracer + optional rviz/rosbag) live in
       drift_traces.launch so they can also run alongside the full nav stack;
       this test passes its own rviz/record args through. -->
  <include file="$(find feeding_deployment)/launch/drift_traces.launch">
    <arg name="rviz" value="$(arg rviz)"/>
    <arg name="record" value="$(arg record)"/>
    <arg name="log_dir" value="$(arg log_dir)"/>
  </include>

  <!-- ZED health monitor, OBSERVATIONAL here: it asserts /nav_safety_hold +
       /nav_safety_hold_reason so you can see WHICH channels (status/silence/
       gap/jump/yank) engage while driving; watch with
         rostopic echo /nav_safety_hold_reason
       Holds never stop driving in this test (teleop is hold-exempt; the
       keyboard tool bypasses the bridge entirely). Expected noise: "clear
       costmaps failed" warnings on yank (no move_base here), and the jump
       channel only auto-pauses for Xbox teleop, so keyboard driving above
       ~0.5 m/s (max_translation over ~2400) will false-trigger it.
       Params verbatim from navigation.launch. -->
  <node if="$(arg monitor)"
        pkg="feeding_deployment"
        type="zed_health_monitor.py"
        name="zed_health_monitor"
        output="screen">
    <param name="odom_topic" value="/zed_mini/zed_node/odom"/>
    <param name="hold_topic" value="/nav_safety_hold"/>
    <param name="max_lin_vel" value="0.5"/>
    <param name="max_ang_vel" value="1.5"/>
    <param name="recovery_stable_s" value="2.0"/>
    <param name="enable_yank_channel" value="true"/>
    <param name="yank_lin_m" value="0.5"/>
    <param name="yank_ang_rad" value="0.4"/>
    <param name="yank_settle_s" value="5.0"/>
    <param name="release_mo_rate_rad_s" value="0.03"/>
    <param name="max_hold_s" value="45.0"/>
  </node>

</launch>
