<launch>
  <!-- Make sure TF + /map + scans are already running:
       - Cartographer (publishing map->odom)
       - UKF/VSLAM (publishing odom->vention_base_link)
       - lidar topics: /lidar_l/scan and /lidar_r/scan
  -->

  <!-- move_base -->
  <!-- move_base -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <!-- <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/> -->
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>

    <rosparam file="$(find feeding_deployment)/config/nav/costmap_common.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find feeding_deployment)/config/nav/costmap_common.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find feeding_deployment)/config/nav/global_costmap.yaml" command="load"/>
    <rosparam file="$(find feeding_deployment)/config/nav/local_costmap.yaml" command="load"/>
    <!-- <rosparam file="$(find feeding_deployment)/config/nav/dwa_local_planner.yaml" command="load"/> -->
    <rosparam file="$(find feeding_deployment)/config/nav/teb_local_planner.yaml" command="load"/>

    <param name="planner_patience" value="15.0"/>
    <param name="controller_patience" value="15.0"/>

    <!-- 0.2 Hz: global replans re-inject Cartographer yaw jitter into TEB via the
         plan; at 1.0 Hz this drove ~1 Hz left/right hunting (navlog_20260706_131121).
         TEB still avoids obstacles locally between replans. -->
    <param name="planner_frequency" value="1"/>
    <param name="controller_frequency" value="10.0"/>
  </node>





  <!-- cmd_vel bridge: /cmd_vel -> set_speeds RPC to BaseInterface on the NUC.
       Runs on the compute box; the Arduino is on the NUC behind base_server.py.
       The lost-command stop lives on the NUC (BaseInterface), not here. -->
  <node pkg="feeding_deployment"
        type="cmd_vel_bridge_basicmicro.py"
        name="cmd_vel_bridge_basicmicro"
        output="screen"
        cwd="node">

    <!-- Physically calibrated 2026-07-09 (direct-serial sweeps): linear_scale ==
         counts_per_meter (4874) so commanded m/s == actual; angular_scale (2600)
         from measured rotation (250 counts/s -> 0.096 rad/s). Speed is governed by
         TEB max_vel_*, NOT by detuning these. WARNING: ~4-6x higher than before, so
         the base now runs the full TEB-commanded speed (0.4 m/s / 0.5 rad/s), for
         teleop AND autonomy; lower TEB max_vel_* before autonomous runs. angular_scale
         measured on a slip-prone patch; verify/re-tune on the deployment floor. -->
    <param name="linear_scale" value="4874.0"/>
    <param name="angular_scale" value="2600.0"/>
    <param name="max_speed_units" value="2500"/>
    <!-- Ratio-preserving stiction floor (units); scales both wheels together so
         slow commands still move without flattening arcs. 0 disables. -->
    <param name="min_move_units" value="100"/>
  </node>

  <!-- zed_health_monitor UNPLUMBED (2026-07-13): odom->base now comes from the
       fused IMU+wheel EKF, so a ZED VIO fault no longer corrupts navigation;
       leaving the monitor here would stop the base on faults in a sensor nav
       doesn't ride anymore. The script stays at scripts/zed_health_monitor.py
       (zed_drift_test.launch still uses it observationally). The bridge and
       manager are no-ops without /nav_safety_hold messages, so nothing else
       changes.
       NOTE: this also unplumbs the map->odom YANK channel (Cartographer
       relocalization/alias hold + costmap clear, which is not a ZED fault).
       Until the Phase-3 step-5 rework lands (EKF-death channel + yank as the
       hard channel, docs/navigation_stack.md), the 180-deg table alias has no
       interlock. -->
</launch>