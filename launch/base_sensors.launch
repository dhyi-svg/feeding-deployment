<launch>
  <!-- Stable: tied to physical USB port -->
  <arg name="port2" default="/dev/serial/by-path/pci-0000:00:14.0-usb-0:4.4.3:1.0-port0"/>
  <arg name="port1" default="/dev/serial/by-path/pci-0000:00:14.0-usb-0:4.4.4:1.0-port0"/>
  <arg name="baud"  default="115200"/>

  <!-- Robot root frame -->
  <arg name="base_frame" default="vention_base_link"/>

  <!-- ===== Lidar Right pose w.r.t. vention_base_link ===== -->
  <arg name="lidar_r_x"   default="0.2575"/>
  <arg name="lidar_r_y"   default="-0.135"/> <!-- -0.3377-->
  <arg name="lidar_r_z"   default="0.415"/> <!-- 0.09 -->
  <arg name="lidar_r_rr"  default="3.14159"/>  <!-- roll  -->
  <arg name="lidar_r_rp"  default="0.0"/>      <!-- pitch -->
  <arg name="lidar_r_ry"  default="0.0"/>      <!-- yaw   -->

  <!-- ===== Lidar Left pose w.r.t. vention_base_link ===== -->
  <arg name="lidar_l_x"   default="0.2575"/>
  <arg name="lidar_l_y"   default="0.135"/> <!-- 0.3377-->
  <arg name="lidar_l_z"   default="0.415"/> <!-- 0.09 -->
  <arg name="lidar_l_rr"  default="3.14159"/>  <!-- roll  -->
  <arg name="lidar_l_rp"  default="0.0"/>      <!-- pitch -->
  <arg name="lidar_l_ry"  default="0.0"/>      <!-- yaw   -->

  <arg name="odom_frame"        default="odom"/>
  <arg name="map_frame"         default="map"/>
  <arg name="camera_name"       default="zed_mini"/>
  <arg name="camera_base_frame" default="zed_mini_base_link"/>
  <arg name="rviz_config"       default="$(find feeding_deployment)/rviz/vention.rviz"/>

  <param name="robot_description"
         textfile="$(find feeding_deployment)/urdf/vention.urdf" />

  <!-- publishes /joint_states (headless) -->
  <node pkg="joint_state_publisher"
        type="joint_state_publisher"
        name="joint_state_publisher" />

  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher" />

  <!-- Static TFs: base -> lidar frames -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_base_to_lidar_r"
        args="$(arg lidar_r_x) $(arg lidar_r_y) $(arg lidar_r_z) $(arg lidar_r_rr) $(arg lidar_r_rp) $(arg lidar_r_ry) $(arg base_frame) lidar_r"/>

  <node pkg="tf2_ros" type="static_transform_publisher" name="tf_base_to_lidar_l"
        args="$(arg lidar_l_x) $(arg lidar_l_y) $(arg lidar_l_z) $(arg lidar_l_rr) $(arg lidar_l_rp) $(arg lidar_l_ry) $(arg base_frame) lidar_l"/>

  <!-- Drivers -->
  <group ns="lidar_r">
    <node pkg="rplidar_ros" type="rplidarNode" name="rplidarNode" output="screen">
      <param name="serial_port" value="$(arg port1)"/>
      <param name="serial_baudrate" value="$(arg baud)"/>
      <param name="frame_id" value="lidar_r"/>
      <param name="angle_compensate" value="true"/>
      <param name="inverted" value="false"/>
    </node>
  </group>

  <group ns="lidar_l">
    <node pkg="rplidar_ros" type="rplidarNode" name="rplidarNode" output="screen">
      <param name="serial_port" value="$(arg port2)"/>
      <param name="serial_baudrate" value="$(arg baud)"/>
      <param name="frame_id" value="lidar_l"/>
      <param name="angle_compensate" value="true"/>
      <param name="inverted" value="false"/>
    </node>
  </group>

  <!-- ===================== -->
  <!-- ZED Mini VIO -->
  <!-- Wrapper fuses camera + IMU internally and publishes
         odom -> zed_mini_base_link directly as TF.
       The URDF parents zed_mini_base_link under vention_base_link
       (joint: vention_base_link_to_zed_base_link), so TF resolves the
       full chain odom -> zed_mini_base_link -> vention_base_link with
       no extra publishers in this launch.
       NOTE: this makes the TF tree effectively rooted at odom, with
       vention_base_link as a child of zed_mini_base_link via URDF
       inverse. Works for a single-sensor setup; revisit (add r_l as a
       frame adapter) if you ever add a second odometry source.
       map -> odom TF is suppressed so Cartographer can own that edge. -->
  <!-- ===================== -->
  <include file="$(find zed_wrapper)/launch/zedm.launch">
    <arg name="camera_name"  value="$(arg camera_name)"/>
    <arg name="camera_model" value="zedm"/>
  </include>

  <!-- TF ownership: ZED owns odom -> zed_mini_base_link,
       URDF owns vention_base_link <-> zed_mini_base_link,
       Cartographer owns map -> odom. -->
  <param name="/$(arg camera_name)/zed_node/pos_tracking/publish_tf"     value="true"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/publish_map_tf" value="false"/>

  <param name="/$(arg camera_name)/zed_node/pos_tracking/odometry_frame" value="$(arg odom_frame)"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/map_frame"      value="$(arg map_frame)"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/base_frame"     value="$(arg camera_base_frame)"/>

<!-- Code to prevent odom drifting in z-axis May 12, 2026 (Bohan)>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/two_d_mode"    value="true"/>
  <param name="/$(arg camera_name)/zed_node/pos_tracking/fixed_z_value" value="0.0"/> -->


  <!-- Convert ZED odom pose deltas into odom feedback for move_base. -->
  <node pkg="feeding_deployment"
        type="zed_pose_to_odom_feedback.py"
        name="zed_pose_to_odom_feedback"
        output="screen">
    <param name="input_odom_topic" value="/$(arg camera_name)/zed_node/odom"/>
    <param name="output_odom_topic" value="/move_base/odom_feedback"/>
  </node>

  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(arg rviz_config)"
        output="screen"/>

</launch>
