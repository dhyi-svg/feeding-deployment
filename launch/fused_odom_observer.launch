<launch>
  <!-- Stage 1 fused-odometry OBSERVER.

       A robot_localization EKF fuses the SANITIZED ZED velocity
       (/move_base/odom_feedback) with the wheel velocity (/wheel_odom) into
       /odometry/fused, alongside the drift-trace observers. The tracer then
       draws five map-anchored lines (drive with teleop, watch/record):

         green  carto          map->base  (lidar-corrected reference)
         red    zed            raw ZED odom            (open loop)
         orange zed_sanitized  sanitized ZED odom      (open loop)
         blue   wheel          /wheel_odom             (open loop)
         purple fused          /odometry/fused (EKF)   (open loop)

       OBSERVE-ONLY: every EKF here has publish_tf false (ekf_zed_wheel.yaml);
       NOTHING downstream consumes these /odometry/fused* variants. Since Jul
       2026 the PROMOTED estimator (wheel + debiased gyro) runs in
       sensors.launch as ekf_fused_imu_wheel -> /odometry/fused_imu_wheel and
       owns odom->base (Stage 2 done); this launch remains the ablation /
       trace harness around it.

       Bring-up (teleop drift test; do NOT run navigation.launch):
         # NUC: base_server up.  compute: sensors.launch + cartographer pane.
         roslaunch feeding_deployment fused_odom_observer.launch record:=true rviz:=true
         rosrun feeding_deployment drift_lock.py   # let localization settle,
                                                   # ENTER to lock, then drive.
       Offline PNG afterward (optionally pass your map yaml for a background):
         python scripts/plot_drift_bag.py
  -->

  <arg name="rviz"    default="false"/>
  <arg name="record"  default="false"/>
  <!-- ablate:=true also spins up the parallel observe-only EKF variants
       (see the ABLATION group below) so the drift traces isolate each
       fusion component. Default off = the original zero-risk observer. -->
  <arg name="ablate"  default="false"/>
  <arg name="log_dir"
       default="$(find feeding_deployment)/src/feeding_deployment/integration/log/system_logs"/>

  <!-- Stamp the raw ZED SDK covariance onto the sanitized velocity (the
       sanitizer drops it) -> /move_base/odom_feedback_cov, the EKF's odom0. -->
  <node pkg="feeding_deployment" type="zed_feedback_cov_relay.py"
        name="zed_feedback_cov_relay" output="screen"/>

  <!-- The fused-odometry EKF. publish_tf:=false lives in the yaml; here we only
       remap the default output topic to /odometry/fused. -->
  <node pkg="robot_localization" type="ekf_localization_node"
        name="ekf_zed_wheel" clear_params="true" output="screen">
    <rosparam command="load"
              file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
    <remap from="odometry/filtered" to="/odometry/fused"/>
  </node>

  <!-- =============================================================== -->
  <!-- ABLATION (ablate:=true): parallel observe-only EKF variants,     -->
  <!-- each loading ekf_zed_wheel.yaml then overriding exactly ONE      -->
  <!-- component, so the drift traces isolate what each piece buys.     -->
  <!-- All keep publish_tf:false (from the yaml); nothing downstream    -->
  <!-- consumes them. imu0 fuses ONLY the gyro yaw-rate (index 11);     -->
  <!-- odom2 is the ZUPT zero-velocity pseudo-measurement.              -->
  <!-- =============================================================== -->
  <group if="$(arg ablate)">

    <!-- ZUPT detector: zero-twist when wheels AND gyro agree we're
         still (feeds the +ZUPT and improved EKFs via /odometry/zupt). -->
    <node pkg="feeding_deployment" type="zupt_publisher.py"
          name="zupt_publisher" output="screen"/>

    <!-- +gyro-yaw: IMU gyro owns yaw-rate; drop ZED vyaw (odom0 index 11). -->
    <node pkg="robot_localization" type="ekf_localization_node"
          name="ekf_zed_wheel_gyro" clear_params="true" output="screen">
      <rosparam command="load"
                file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
      <rosparam param="odom0_config">[false, false, false, false, false, false, true, true, false, false, false, false, false, false, false]</rosparam>
      <param name="imu0" value="/zed_mini/zed_node/imu/data"/>
      <rosparam param="imu0_config">[false, false, false, false, false, false, false, false, false, false, false, true, false, false, false]</rosparam>
      <param name="imu0_differential" value="false"/>
      <param name="imu0_relative" value="false"/>
      <param name="imu0_queue_size" value="20"/>
      <remap from="odometry/filtered" to="/odometry/fused_gyro"/>
    </node>

    <!-- +reject-gate: Mahalanobis innovation gate on the ZED velocity. -->
    <node pkg="robot_localization" type="ekf_localization_node"
          name="ekf_zed_wheel_gate" clear_params="true" output="screen">
      <rosparam command="load"
                file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
      <param name="odom0_twist_rejection_threshold" value="5.0"/>
      <remap from="odometry/filtered" to="/odometry/fused_gate"/>
    </node>

    <!-- +ZUPT: stock fusion + zero-velocity update (odom2). -->
    <node pkg="robot_localization" type="ekf_localization_node"
          name="ekf_zed_wheel_zupt" clear_params="true" output="screen">
      <rosparam command="load"
                file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
      <param name="odom2" value="/odometry/zupt"/>
      <rosparam param="odom2_config">[false, false, false, false, false, false, true, true, false, false, false, true, false, false, false]</rosparam>
      <param name="odom2_differential" value="false"/>
      <param name="odom2_relative" value="false"/>
      <param name="odom2_queue_size" value="10"/>
      <remap from="odometry/filtered" to="/odometry/fused_zupt"/>
    </node>

    <!-- improved (all): gyro-yaw + reject-gate + ZUPT together. -->
    <node pkg="robot_localization" type="ekf_localization_node"
          name="ekf_zed_wheel_improved" clear_params="true" output="screen">
      <rosparam command="load"
                file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
      <rosparam param="odom0_config">[false, false, false, false, false, false, true, true, false, false, false, false, false, false, false]</rosparam>
      <param name="odom0_twist_rejection_threshold" value="5.0"/>
      <param name="imu0" value="/zed_mini/zed_node/imu/data"/>
      <rosparam param="imu0_config">[false, false, false, false, false, false, false, false, false, false, false, true, false, false, false]</rosparam>
      <param name="imu0_differential" value="false"/>
      <param name="imu0_relative" value="false"/>
      <param name="imu0_queue_size" value="20"/>
      <param name="odom2" value="/odometry/zupt"/>
      <rosparam param="odom2_config">[false, false, false, false, false, false, true, true, false, false, false, true, false, false, false]</rosparam>
      <param name="odom2_differential" value="false"/>
      <param name="odom2_relative" value="false"/>
      <param name="odom2_queue_size" value="10"/>
      <remap from="odometry/filtered" to="/odometry/fused_improved"/>
    </node>

    <!-- no-VIO (specialized): wheel vx + IMU yaw only. ZED dropped by
         pointing odom0 at a topic nobody publishes (config stays, no msgs). -->
    <node pkg="robot_localization" type="ekf_localization_node"
          name="ekf_zed_wheel_novio" clear_params="true" output="screen">
      <rosparam command="load"
                file="$(find feeding_deployment)/config/nav/ekf_zed_wheel.yaml"/>
      <param name="odom0" value="/odometry/_novio_zed_disabled"/>
      <param name="imu0" value="/zed_mini/zed_node/imu/data"/>
      <rosparam param="imu0_config">[false, false, false, false, false, false, false, false, false, false, false, true, false, false, false]</rosparam>
      <param name="imu0_differential" value="false"/>
      <param name="imu0_relative" value="false"/>
      <param name="imu0_queue_size" value="20"/>
      <remap from="odometry/filtered" to="/odometry/fused_novio"/>
    </node>

    <!-- NOTE: the debiased-gyro estimator (gyro_bias_estimator) and the
         wheel+debiased-IMU EKF now run LIVE in sensors.launch as the
         authoritative odom source (ekf_fused_imu_wheel ->
         /odometry/fused_imu_wheel, the GOLD trace). They are no longer
         started here; the tracer/bag pick the live topics up directly. -->

  </group>

  <!-- Drift-trace observers (wheel_odom_publisher + drift_trace_compare, now
       with the purple /drift_test/fused_path). record:=false here; we own one
       superset bag below so it also captures the fused topics + baked Paths. -->
  <include file="$(find feeding_deployment)/launch/drift_traces.launch">
    <arg name="rviz"   value="$(arg rviz)"/>
    <arg name="record" value="false"/>
  </include>

  <!-- One bag: the drift_traces set PLUS the fused inputs/output and the baked
       /drift_test/*_path topics, so plot_drift_bag.py needs no offline TF math.
       (Recording the growing Paths costs some MB on a long run; fine for a
       short drift loop.) -->
  <node if="$(arg record)" pkg="rosbag" type="record" name="fused_drift_record"
        args="record -o $(arg log_dir)/fused_drift
              /tf /tf_static /cmd_vel_teleop
              /zed_mini/zed_node/odom /zed_mini/zed_node/odom_sanitized
              /move_base/odom_feedback /move_base/odom_feedback_cov /odometry/fused
              /wheel_odom /wheel_odom/counts /wheel_odom/side_disagreement
              /nav_safety_hold /nav_safety_hold_reason
              /zed_mini/zed_node/imu/data
              /zed_mini/zed_node/imu/data_debiased /gyro_bias_estimate
              /odometry/zupt
              /odometry/fused_gyro /odometry/fused_gate /odometry/fused_zupt
              /odometry/fused_improved /odometry/fused_novio
              /odometry/fused_imu_wheel
              /drift_test/anchor
              /drift_test/carto_path /drift_test/zed_path
              /drift_test/zed_sanitized_path /drift_test/wheel_path
              /drift_test/fused_path
              /drift_test/fused_gyro_path /drift_test/fused_gate_path
              /drift_test/fused_zupt_path /drift_test/fused_improved_path
              /drift_test/fused_novio_path /drift_test/fused_imu_wheel_path
              /lidar_r/scan /lidar_l/scan"/>
</launch>
